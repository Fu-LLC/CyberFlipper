App(
    appid="nyanbox_detector",
    name="[F] nyanBOX Detect",
    apptype=FlipperAppType.EXTERNAL,
    entry_point="nyanbox_detector_app",
    requires=["gui", "furi", "bt"],
    stack_size=4 * 1024,
