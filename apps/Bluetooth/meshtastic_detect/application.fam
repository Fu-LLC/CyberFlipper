App(
    appid="meshtastic_detect",
    name="[F] Meshtastic Detect",
    apptype=FlipperAppType.EXTERNAL,
    entry_point="meshtastic_detect_app",
    requires=["gui", "furi", "bt"],
    stack_size=4 * 1024,
    fap_category="Bluetooth",
    fap_version="1.1.0",
    fap_author="Personfu",
    fap_description="Detects nearby Meshtastic and MeshCore mesh networking devices via BLE service UUIDs",
)
